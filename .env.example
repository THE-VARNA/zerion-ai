# ─── Required ─────────────────────────────────────────────────────────────────

# Zerion API key — get one at https://dashboard.zerion.io (begins with zk_)
# Required for all analysis and trading commands.
ZERION_API_KEY=zk_dev_...

# Passphrase for the local encrypted keystore.
# Required when treasury trigger runs in LIVE mode (not dry-run).
TREASURY_WALLET_PASSPHRASE=your-secure-passphrase

# ─── Treasury Agent ────────────────────────────────────────────────────────────

# Custom path to treasury-policy.json (default: ~/.zerion/treasury-policy.json)
TREASURY_POLICY_PATH=~/.zerion/treasury-policy.json

# ─── x402 Pay-Per-Call (no API key needed) ────────────────────────────────────
# See: https://developers.zerion.io/build-with-ai/x402

# EVM private key (0x-prefixed hex) for x402 payments on Base.
# Also used as the default for MPP payments on Tempo.
WALLET_PRIVATE_KEY=0x...

# Dedicated EVM key for x402 on Base (overrides WALLET_PRIVATE_KEY for EVM).
# EVM_PRIVATE_KEY=0x...

# Dedicated Solana key for x402 on Solana (base58-encoded keypair).
# SOLANA_PRIVATE_KEY=5C1y...

# Set to "true" to enable x402 globally for all analytics commands.
# ZERION_X402=true

# Set to "true" to prefer Solana over Base when both keys are set.
# ZERION_X402_PREFER_SOLANA=true

# ─── Custom RPC Endpoints (optional) ──────────────────────────────────────────

# Custom Ethereum RPC (used for ENS resolution).
# ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_KEY

# Custom Solana RPC endpoint.
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
